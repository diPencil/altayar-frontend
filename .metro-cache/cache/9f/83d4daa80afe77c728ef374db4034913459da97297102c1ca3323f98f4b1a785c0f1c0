.\",\n      \"q10\": \"ماذا يحدث إذا تأخرت رحلتي؟\",\n      \"a10\": \"تتعامل شركات الطيران عادةً مع التأخيرات مباشرة. ومع ذلك، يمكن لفريق الدعم لدينا مساعدتك في إيجاد بدائل إذا لزم الأمر.\",\n      \"q11\": \"كيف يمكنني تغيير معلومات ملفي الشخصي؟\",\n      \"a11\": \"اذهب إلى الملف الشخصي > تعديل الملف الشخصي لتحديث اسمك، بريدك الإلكتروني، أو رقم هاتفك.\",\n      \"q12\": \"هل بياناتي آمنة؟\",\n      \"a12\": \"نعم، نستخدم تشفيراً قياسياً لحماية بياناتك الشخصية وبيانات الدفع.\",\n      \"q13\": \"هل أحتاج إلى تأشيرة لرحلتي؟\",\n      \"a13\": \"تعتمد متطلبات التأشيرة على وجهتك وجنسيتك. نوصي بمراجعة السفارة أو استخدام خدمة المساعدة في التأشيرات لدينا.\",\n      \"q14\": \"هل يمكنني الدفع بالتقسيط؟\",\n      \"a14\": \"حالياً، نقدم خيارات الدفع الكامل. تحقق لاحقاً لمعرفة خطط التقسيط.\",\n      \"q15\": \"أين يمكنني العثور على قسيمة الحجز؟\",\n      \"a15\": \"يتم إرسال القسيمة إليك عبر البريد الإلكتروني وهي متاحة أيضاً في قسم 'حجوزاتي' في التطبيق.\",\n      \"q16\": \"كيف أعيد تعيين كلمة المرور؟\",\n      \"a16\": \"في شاشة تسجيل الدخول، اضغط على 'نسيت كلمة المرور' واتبع التعليمات المرسلة إلى بريدك الإلكتروني.\",\n      \"q17\": \"هل الضرائب مشمولة في السعر؟\",\n      \"a17\": \"نعم، جميع الأسعار المعروضة تشمل الضرائب المطبقة ما لم يذكر خلاف ذلك.\",\n      \"q18\": \"هل يمكنني إضافة طلبات خاصة؟\",\n      \"a18\": \"نعم، يمكنك إضافة ملاحظات (مثل تفضيلات النظام الغذائي، الكرسي المتحرك) أثناء عملية الحجز.\",\n      \"q19\": \"ما هو وزن الأمتعة المسموح به؟\",\n      \"a19\": \"تختلف سياسات الأمتعة حسب شركة الطيران وفئة التذكرة. تحقق من تفاصيل رحلتك المحددة للحصول على هذه المعلومات.\",\n      \"q20\": \"كيف أترك تقييماً؟\",\n      \"a20\": \"بعد اكتمال رحلتك، ستتلقى إشعاراً لتقييم تجربتك وترك ملاحظاتك.\",\n      \"q21\": \"هل يمكنني حجز تأجير سيارات؟\",\n      \"a21\": \"نعم، نقدم خدمة تأجير السيارات في العديد من الوجهات. ابحث عن قسم 'تأجير السيارات' في الشاشة الرئيسية.\",\n      \"q22\": \"هل تقدمون تأمين سفر؟\",\n      \"a22\": \"نعم، نوصي بشدة بإضافة تأمين السفر إلى حجزك لراحة بالك. يمكنك اختياره أثناء عملية الدفع.\",\n      \"q23\": \"كيف يمكنني طلب فاتورة؟\",\n      \"a23\": \"يتم إنشاء الفواتير تلقائياً وتتوفر في تفاصيل حجزك أو يتم إرسالها إلى بريدك الإلكتروني.\",\n      \"q24\": \"ما هو الحد الأقصى لعدد الأشخاص في الحجز الواحد؟\",\n      \"a24\": \"يعتمد هذا على مزود الخدمة. عادةً، بالنسبة للفنادق، يكون 3-4 أشخاص في الغرفة؛ للمجموعات، يرجى التواصل مع فريق الدعم.\",\n      \"q25\": \"هل توجد أي رسوم خفية؟\",\n      \"a25\": \"لا، نحن نؤمن بالشفافية. يتم عرض جميع الرسوم الإلزامية قبل تأكيد حجزك.\",\n      \"q26\": \"هل يمكنني كسب نقاط في كل حجز؟\",\n      \"a26\": \"نعم، جميع الحجوزات المؤكدة تمنحك نقاط عضوية بناءً على مستواك الحالي.\",\n      \"q27\": \"ما هو برنامج الولاء؟\",\n      \"a27\": \"يكافئ برنامج الولاء الخاص بنا المسافرين الدائمين بنقاط وعروض حصرية ومزايا حسب المستوى مثل ترقيات الغرف.\",\n      \"q28\": \"هل يمكنني تغيير تاريخ رحلتي؟\",\n      \"a28\": \"تغيير التاريخ يخضع لمدى توفر شركة الطيران والرسوم. تواصل مع فريق الدعم للتحقق من خياراتك.\",\n      \"q29\": \"كيف أعرف إذا تم الدفع بنجاح؟\",\n      \"a29\": \"ستظهر لك شاشة تأكيد وستتلقى إشعاراً فورياً عبر البريد الإلكتروني بمجرد معالجة الدفع.\",\n      \"q30\": \"هل لديكم تطبيق للهواتف المحمولة للأندرويد والآيفون؟\",\n      \"a30\": \"نعم، تطبيق الطيار متاح في كل من متجر جوجل بلاي ومتجر آبل ستور.\"\n    }\n  },\n  \"wallet\": {\n    \"title\": \"محفظتي\",\n    \"balance\": \"الرصيد الحالي\",\n    \"transactions\": \"المعاملات\",\n    \"noTransactions\": \"لا توجد معاملات بعد\",\n    \"empty\": \"لا توجد معاملات\",\n    \"currency\": \"USD\",\n    \"transaction\": \"معاملة\"\n  },\n  \"points\": {\n    \"title\": \"نقاطي\",\n    \"available\": \"النقاط المتاحة\",\n    \"totalEarned\": \"إجمالي المكتسب\",\n    \"redeem\": \"استبدال النقاط\",\n    \"progress\": \"التقدم للمستوى التالي\",\n    \"history\": \"سجل النقاط\",\n    \"noHistory\": \"لا توجد معاملات بعد\",\n    \"nextTier\": \"{{points}} نقطة للمستوى البلاتيني\",\n    \"tier\": {\n      \"gold\": \"ذهبي\",